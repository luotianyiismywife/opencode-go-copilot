{
	"name": "opencode-go-copilot-provider",
	"publisher": "OnesoftQwQ",
	"displayName": "OpenCode Go Provider for Copilot",
	"description": "Integrate OpenCode Go models into GitHub Copilot Chat",
	"icon": "assets/logo.png",
	"keywords": [
		"ai",
		"chat",
		"copilot",
		"github-copilot",
		"language-model",
		"llm",
		"opencode",
		"openai-compatible",
		"thinking",
		"git-commit"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/OnesoftQwQ/opencode-go-copilot"
	},
	"homepage": "https://github.com/OnesoftQwQ/opencode-go-copilot",
	"bugs": {
		"url": "https://github.com/OnesoftQwQ/opencode-go-copilot/issues"
	},
	"version": "1.4.0",
	"engines": {
		"vscode": "^1.116.0"
	},
	"categories": [
		"AI",
		"Chat"
	],
	"license": "MIT",
	"contributes": {
		"languageModelChatProviders": [
			{
				"vendor": "opencodego",
				"displayName": "%providerDisplayName%",
				"managementCommand": "opencodego.setApiKey"
			}
		],
		"commands": [
			{
				"command": "opencodego.setApiKey",
				"category": "%commandCategory%",
				"title": "%command.setApiKey%"
			},
			{
				"command": "opencodego.generateGitCommitMessage",
				"title": "%command.generateCommit%",
				"category": "%commandCategory%",
				"icon": "$(wand)"
			},
			{
				"command": "opencodego.abortGitCommitMessage",
				"title": "%command.abortCommit%",
				"category": "%commandCategory%",
				"icon": "$(debug-stop)"
			},
			{
				"command": "opencodego.setModelPreset",
				"category": "%commandCategory%",
				"title": "%command.setModelPreset%"
			}
		],
		"menus": {
			"scm/title": [
				{
					"command": "opencodego.generateGitCommitMessage",
					"group": "navigation",
					"when": "config.git.enabled && scmProvider == git && !opencodego.isGeneratingCommit"
				},
				{
					"command": "opencodego.abortGitCommitMessage",
					"group": "navigation",
					"when": "config.git.enabled && scmProvider == git && opencodego.isGeneratingCommit"
				}
			],
			"commandPalette": [
				{
					"command": "opencodego.generateGitCommitMessage",
					"when": "config.git.enabled && !opencodego.isGeneratingCommit"
				},
				{
					"command": "opencodego.abortGitCommitMessage",
					"when": "config.git.enabled && opencodego.isGeneratingCommit"
				}
			]
		},
		"configuration": {
			"title": "%config.title%",
			"properties": {
				"opencodego.commitLanguage": {
					"type": "string",
					"default": "auto",
					"enum": [
						"auto",
						"English",
						"French",
						"Italian",
						"German",
						"Spanish",
						"Russian",
						"Chinese (Simplified)",
						"Chinese (Traditional)",
						"Japanese",
						"Korean",
						"Czech",
						"Portuguese (Brazil)",
						"Turkish",
						"Polish"
					],
					"enumDescriptions": [
						"%config.commitLanguage.auto.desc%",
						"%config.commitLanguage.enum.English.desc%",
						"%config.commitLanguage.enum.French.desc%",
						"%config.commitLanguage.enum.Italian.desc%",
						"%config.commitLanguage.enum.German.desc%",
						"%config.commitLanguage.enum.Spanish.desc%",
						"%config.commitLanguage.enum.Russian.desc%",
						"%config.commitLanguage.enum.ChineseSimplified.desc%",
						"%config.commitLanguage.enum.ChineseTraditional.desc%",
						"%config.commitLanguage.enum.Japanese.desc%",
						"%config.commitLanguage.enum.Korean.desc%",
						"%config.commitLanguage.enum.Czech.desc%",
						"%config.commitLanguage.enum.PortugueseBrazil.desc%",
						"%config.commitLanguage.enum.Turkish.desc%",
						"%config.commitLanguage.enum.Polish.desc%"
					],
					"description": "%config.commitLanguage.desc%"
				},
				"opencodego.commitModel": {
					"type": "string",
					"default": "deepseek-v4-flash",
					"description": "%config.commitModel.desc%"
				},
				"opencodego.commitMessagePrompt": {
					"type": "string",
					"default": "",
					"description": "%config.commitMessagePrompt.desc%"
				},
				"opencodego.requestTimeout": {
					"type": "number",
					"default": 600000,
					"minimum": 10000,
					"description": "%config.requestTimeout.desc%"
				},
				"opencodego.recentCommitsCount": {
					"type": "number",
					"default": 10,
					"minimum": 0,
					"maximum": 50,
					"description": "%config.recentCommitsCount.desc%"
				},
				"opencodego.commitIncludeCommitDiff": {
					"type": "boolean",
					"default": false,
					"description": "%config.commitIncludeCommitDiff.desc%"
				},
				"opencodego.commitAttachContextFiles": {
					"type": "boolean",
					"default": true,
					"description": "%config.commitAttachContextFiles.desc%"
				},
				"opencodego.modelPreset": {
					"type": "string",
					"default": "precise",
					"description": "%config.modelPreset.desc%",
					"editPresentation": "singlelineText"
				},
				"opencodego.temperature": {
					"type": "number",
					"default": null,
					"minimum": 0,
					"maximum": 2,
					"description": "%config.temperature.desc%"
				},
				"opencodego.top_p": {
					"type": "number",
					"default": null,
					"minimum": 0,
					"maximum": 1,
					"description": "%config.top_p.desc%"
				},
				"opencodego.enableZenFreeModels": {
					"type": "boolean",
					"default": false,
					"description": "%config.enableZenFreeModels.desc%"
				},
				"opencodego.modelPresets": {
					"type": "array",
					"default": [
						{
							"id": "precise",
							"label": "Precise",
							"temperature": 0
						},
						{
							"id": "balanced",
							"label": "Balanced",
							"temperature": 1
						},
						{
							"id": "creative",
							"label": "Creative",
							"temperature": 1.2
						},
						{
							"id": "extra-creative",
							"label": "Extra Creative",
							"temperature": 1.7
						}
					],
					"items": {
						"type": "object",
						"required": [
							"id",
							"label",
							"temperature"
						],
						"properties": {
							"id": {
								"type": "string",
								"description": "%config.modelPreset.id.desc%"
							},
							"label": {
								"type": "string",
								"description": "%config.modelPreset.label.desc%"
							},
							"temperature": {
								"type": "number",
								"description": "%config.modelPreset.temperature.desc%"
							},
							"top_p": {
								"type": "number",
								"description": "%config.modelPreset.top_p.desc%"
							}
						}
					},
					"description": "%config.modelPresets.desc%"
				},
				"opencodego.visionProxyModel": {
					"type": "string",
					"default": "qwen3.6-plus",
					"description": "%config.visionProxyModel.desc%"
				},
				"opencodego.visionProxyPrompt": {
					"type": "string",
					"default": "Describe this image in detail. Include visible text, objects, UI elements, people, and relevant context. Do not invent details.",
					"description": "%config.visionProxyPrompt.desc%"
				},
				"opencodego.visionProxyThinking": {
					"type": "boolean",
					"default": false,
					"description": "%config.visionProxyThinking.desc%"
				},
				"opencodego.enableThirdPartyTokenIndicator": {
					"type": "boolean",
					"default": true,
					"description": "%config.enableThirdPartyTokenIndicator.desc%"
				}
			}
		}
	},
	"main": "./out/extension.js",
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"compile": "tsc -p ./",
		"lint": "eslint",
		"watch": "tsc -watch -p ./",
		"build": "npx @vscode/vsce package -o extension.vsix",
		"postinstall": "node scripts/copy-tokenizer.js"
	},
	"dependencies": {
		"@microsoft/tiktokenizer": "^1.0.10"
	},
	"devDependencies": {
		"@types/node": "^22",
		"@types/vscode": "^1.116.0",
		"typescript": "^5.9.2"
	}
}
